{
  "name": "template",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "fix": "bash scripts/fix.sh",
    "update:deps": "pnpm update -r",
    "update:skills": "npx --yes skills update --project --yes && pnpm -r --workspace-concurrency=1 exec npx --yes skills update --project --yes",
    "sync:design-system": "node scripts/sync-design-system.mjs",
    "sync:shadcn": "npx shadcn@latest diff -c packages/ui"
  },
  "devDependencies": {
    "oxc-parser": "^0.129.0",
    "oxc-resolver": "^11.21.3",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.22.1",
    "turbo": "^2.9.18",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11.1.2"
  },
  "packageManager": "pnpm@11.1.2"
}
